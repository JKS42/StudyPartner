# Copy to apps/mobile/.env (this app is Expo, not Next.js)

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
EXPO_PUBLIC_SUPABASE_FUNCTIONS_URL=https://your-project.supabase.co/functions/v1

# Optional OAuth redirect (Expo Go auto-detects exp:// — do NOT use YOUR_IP placeholders)
# EXPO_PUBLIC_AUTH_REDIRECT_URI=studypartner://auth/callback

# Next.js templates use NEXT_PUBLIC_* and @supabase/ssr — not used in this repo.
